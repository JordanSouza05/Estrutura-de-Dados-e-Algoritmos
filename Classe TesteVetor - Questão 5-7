public class TesteVetor {
    private String[] vetor;
    private int tamanhoAtual;

    public TesteVetor(int capacidade) {
        this.vetor = new String[capacidade];
        this.tamanhoAtual = 0;
    }
    public void adicionar(String elemento) {
        if (tamanhoAtual < vetor.length) {
            vetor[tamanhoAtual] = elemento;
            tamanhoAtual++;
        } else {
            System.out.println("Erro: vetor cheio!");
        }
    }
    public int tamanho() {
        return tamanhoAtual;
    }
    public void imprimir() {
        System.out.print("[");
        for (int i = 0; i < tamanhoAtual; i++) {
            System.out.print(vetor[i]);
            if (i < tamanhoAtual - 1) {
                System.out.print(", ");
            }
        }
        System.out.println("]");
    }
    public void imprimirElementos() {
        for (int i = 0; i < tamanhoAtual; i++) {
            System.out.println(vetor[i]);
        }
    }
    public boolean contem(String elemento) {
        for (int i = 0; i < tamanhoAtual; i++) {
            if (vetor[i].equals(elemento)) {
                return true;
            }
        }
        return false;
    }
    public int buscar(String elemento) {
        for (int i = 0; i < tamanhoAtual; i++) {
            if (vetor[i].equals(elemento)) {
                return i;
            }
        }
        return -1;
    }
    public String ultimo() throws Exception {
        if (tamanhoAtual == 0) {
            throw new Exception("O vetor está vazio!");
        }
        return vetor[tamanhoAtual - 1];
    }
}
