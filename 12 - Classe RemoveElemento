public class RemoveElemento {

    public static boolean remove(String[] vetor, String elemento) {

        for (int i = 0; i < vetor.length; i++) {

            if (vetor[i] != null && vetor[i].equals(elemento)) {

                for (int j = i; j < vetor.length - 1; j++) {
                    vetor[j] = vetor[j + 1];
                }

                vetor[vetor.length - 1] = null;

                return true;
            }

        }

        return false;
    }

}
